@model List<YouTubeDownloader.Domain.Entities.DownloadJob>

@{
    ViewData["Title"] = "YouTube Downloader";
}

@functions {
    public string FormatBytes(long? bytes)
    {
        if (bytes == null || bytes == 0)
            return "0 MB";

        string[] sizes = { "B", "KB", "MB", "GB", "TB" };
        double len = bytes.Value;
        int order = 0;

        while (len >= 1024 && order < sizes.Length - 1)
        {
            order++;
            len /= 1024;
        }

        return $"{len:0.##} {sizes[order]}";
    }
}

<div class="container py-5">

    <div class="text-center mb-5">
        <h1 class="fw-bold">YouTube Video Downloader</h1>
        <p class="text-muted">
            Paste a YouTube URL, process the video, and download the final file.
        </p>
    </div>

    <div class="card shadow-lg border-0 rounded-4 mb-5">
        <div class="card-body p-4">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <label class="form-label fw-bold">YouTube Video URL</label>

                <div class="input-group input-group-lg">
                    <input name="VideoUrl"
                           class="form-control"
                           placeholder="https://www.youtube.com/watch?v=..." />

                    <button class="btn btn-danger px-4">
                        Download
                    </button>
                </div>

                <small class="text-muted d-block mt-2">
                    Only download videos you have permission to save or reuse.
                </small>
            </form>
        </div>
    </div>

    <h4 class="fw-bold mb-3">Download History</h4>

    @if (!Model.Any())
    {
        <div class="alert alert-light border text-center">
            No downloads yet.
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden">
                        <img src="@item.ThumbnailUrl"
                             class="card-img-top"
                             style="height:180px; object-fit:cover;" />

                        <div class="card-body">
                            <h6 class="fw-bold">
                                @item.VideoTitle
                            </h6>

                            <span class="badge bg-primary mb-2">
                                @item.Status
                            </span>

                            <div class="progress mb-2" style="height: 10px;">
                                <div class="progress-bar"
                                     style="width:@item.Progress%">
                                </div>
                            </div>

                            <small class="text-muted">
                                @FormatBytes(item.DownloadedBytes) of @FormatBytes(item.TotalBytes)
                            </small>
                        </div>

                        <div class="card-footer bg-white border-0 pb-3">
                            @if (item.Status == YouTubeDownloader.Domain.Enums.DownloadStatus.Completed)
                            {
                                <a href="@item.OutputFilePath"
                                   class="btn btn-success w-100 rounded-pill"
                                   download>
                                    Download File
                                </a>
                            }
                            else
                            {
                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-outline-primary w-100 rounded-pill">
                                    View Progress
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>